  "keyFeatures": [
    "JWT-based authentication and authorization",
    "Role-based access control (Admin/User)",
    "Public catalog with book browsing",
    "Loan request management system",
    "Admin panel for managing books, authors, and genres",
    "HTTP interceptors for automatic token injection",
    "Dockerized deployment with multi-stage builds",
    "CI/CD pipeline with GitHub Actions"
  ],
